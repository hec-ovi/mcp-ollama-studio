# === APP ===
APP_NAME=MCP Ollama Studio API
APP_ENV=development
API_PREFIX=/api/v1
CORS_ORIGINS_RAW=http://localhost:5173,http://localhost:4173,http://localhost:3000

# === HOST PATHS ===
OLLAMA_MODELS_DIR=/home/hector/models/ollama

# === OLLAMA CONTAINER ===
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_CONTEXT_LENGTH=8192
OLLAMA_KEEP_ALIVE=5m

# === LLM (OpenAI-compatible v1 adapter) ===
# Default points to the in-compose Ollama container:
LLM_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=gpt-oss:20b
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=120

# === Frontend ===
VITE_API_BASE_URL=http://localhost:8000
